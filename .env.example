# Default LLM provider: openai | anthropic | ollama
WILLBE_LLM_PROVIDER=openai

# Web search (enabled by default)
WILLBE_WEB_SEARCH_ENABLED=true
WILLBE_SEARCH_PROVIDER=duckduckgo
WILLBE_PREFERRED_SOURCES_PATH=config/preferred_sources.yaml
WILLBE_SEARCH_MAX_RESULTS_PER_QUERY=4
WILLBE_SEARCH_MAX_CITATIONS=10
WILLBE_IMAGE_SEARCH_ENABLED=true
WILLBE_IMAGE_SEARCH_MAX_RESULTS=3

# Tavily (optional search provider)
TAVILY_API_KEY=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Database + API
WILLBE_DATABASE_URL=sqlite:///./data/willbe.db
WILLBE_API_HOST=127.0.0.1
WILLBE_API_PORT=8000
WILLBE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional HTTP basic auth for production deployments
WILLBE_HTTP_AUTH_USER=
WILLBE_HTTP_AUTH_PASSWORD=

# Google Trends API (alpha) — OAuth credentials, not a simple API key
# Apply for alpha access: https://developers.google.com/search/apis/trends
GOOGLE_TRENDS_PROJECT_ID=
GOOGLE_TRENDS_CREDENTIALS_PATH=
GOOGLE_TRENDS_TOKEN_PATH=.cache/google-trends-token.json
GOOGLE_TRENDS_GEO_REGION=global
